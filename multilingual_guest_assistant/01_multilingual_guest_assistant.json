          }
        ]
      ]
    },
    "Guest Conversation Memory": {
      "ai_memory": [
        [
          {
            "node": "Guest Assistant Agent",
            "type": "ai_memory",
            "index": 0
          }
        ]
      ]
    },
    "Reply Structure Parser": {
      "ai_outputParser": [
        [
          {
            "node": "Guest Assistant Agent",
            "type": "ai_outputParser",
            "index": 0
          }
        ]
      ]
    },
    "Guest Assistant Agent": {
      "main": [
        [
          {
            "node": "Needs Human?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Needs Human?": {
      "main": [
        [
          {
            "node": "Notify Front Desk",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Route By Channel",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Notify Front Desk": {
      "main": [
        [
          {
            "node": "Route By Channel",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Route By Channel": {
      "main": [
        [
          {
            "node": "Send WhatsApp Reply",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Send Viber Reply",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send WhatsApp Reply": {
      "main": [
        [
          {
