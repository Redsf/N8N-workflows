      ],
      "parameters": {
        "color": 6,
        "width": 320,
        "height": 448,
        "content": "## 3️⃣ Alert\n\n**Alert Manager** posts every flagged review to your team channel so someone can respond quickly."
      },
      "typeVersion": 1
    },
    {
