  "nodes": [
    {
      "id": "435ff51d-6fa7-4949-b01e-4a4f2150fa3c",
      "name": "Overview",
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        -368,
        -192
      ],
      "parameters": {
        "color": 7,
        "width": 560,
        "height": 616,
        "content": "## ⭐ Negative Review Monitor\n\nChecks your review feed every 6 hours, isolates low rated reviews, and instantly alerts your manager in Slack so issues get handled fast.\n\n**Perfect for:** restaurants, cafes and hospitality venues.\n\n## How it works\n\n1. **Every 6 Hours**: schedule trigger that polls on a fixed interval.\n2. **Fetch Latest Reviews**: calls your review source and returns recent reviews.\n3. **Filter Negative Reviews**: keeps only reviews rated 3 stars or lower.\n4. **Any Negative Reviews**: continues only if at least one was found.\n5. **Alert Manager**: posts each negative review to your manager channel.\n\n## Setup (about 10 minutes)\n\n1. **HTTP Request**: set your review endpoint URL in *Fetch Latest Reviews* and add auth if needed.\n2. **Slack**: connect Slack and set the channel in *Alert Manager*.\n> Adjust the rating cutoff in *Filter Negative Reviews* if you want to flag only 1 and 2 star reviews."
      },
      "typeVersion": 1
    },
    {
      "id": "eba15a52-1e3c-4a2b-a9b6-1db16012e453",
      "name": "1️⃣ Poll Reviews",
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        240,
        -32
      ],
      "parameters": {
        "color": 5,
        "width": 520,
        "height": 432,
        "content": "## 1️⃣ Poll Reviews\n\n**Every 6 Hours** runs on a schedule and **Fetch Latest Reviews** pulls the most recent reviews from your chosen source."
      },
      "typeVersion": 1
    },
    {
      "id": "c153907b-4eee-4dae-a3b3-a744353591da",
      "name": "2️⃣ Detect Issues",
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        784,
        -32
      ],
      "parameters": {
        "color": 3,
        "width": 600,
        "height": 432,
        "content": "## 2️⃣ Detect Issues\n\n**Filter Negative Reviews** keeps only low rated entries, then **Any Negative Reviews** stops the run when there is nothing to report."
      },
      "typeVersion": 1
    },
    {
      "id": "0fdb9a55-a9a4-4bf3-984b-f5282504a430",
      "name": "3️⃣ Alert",
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        1408,
