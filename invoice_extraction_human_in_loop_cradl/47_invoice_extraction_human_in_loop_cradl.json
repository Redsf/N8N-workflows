    {
      "id": "eeb14e92-e7fd-4c50-ba5f-0a0063ea49a2",
      "name": "Duplicate Check",
      "type": "n8n-nodes-base.code",
      "position": [
        1280,
        40
      ],
      "typeVersion": 2,
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Runs once per execution. Cross-references every invoice extracted this run\n// (from \"Validate & Score\") against every invoice_number already on record\n// (from \"Fetch Existing Invoice Numbers\"), without relying on 1:1 item pairing,\n// which breaks here because the two branches have different item counts.\nconst invoices = $('Validate & Score').all().map(i => i.json);\nconst existingRows = $input.all().map(i => i.json);\n\n// ASSUMPTION: the Google Sheet has a column literally named \"invoice_number\".\n// Update the key below if your header differs.\nconst existingNumbers = new Set(\n  existingRows.map(r => String(r.invoice_number || '').trim()).filter(Boolean)\n);\n\nreturn invoices.map(inv => ({\n  json: {\n    ...inv,\n    isDuplicate: existingNumbers.has(String(inv.invoiceNumber || '').trim())\n  }\n}));\n"
      }
    },
