    {
      "id": "83d293c8-9f35-4742-a9bc-ef002ba70a21",
      "name": "Extract invoice details with AI",
      "type": "@cradl/n8n-nodes-cradlai.cradlAi",
      "position": [
        560,
        40
      ],
      "typeVersion": 1,
      "webhookId": "d5e14889-bcc4-4623-8def-a69f7a2e212a",
      "parameters": {
        "agentId": "cradl:agent:556e3aa0d2214b6c899c631b78a5cd43",
        "documentBinaryData": "data"
      },
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000
    },
    {
      "id": "d5d64226-d8ca-4a50-912b-4ee25966d2fd",
      "name": "Validate & Score",
      "type": "n8n-nodes-base.code",
      "position": [
        800,
        40
      ],
      "typeVersion": 2,
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "// Score the AI-extracted invoice for completeness and internal consistency.\n// ASSUMPTION (please verify against a real execution): the cradl agent returns\n// body.output.{invoice_number, vendor_name, currency, invoice_total, invoice_lines[].amount}.\n// Adjust the field paths below if your agent's schema differs.\nconst j = $json;\nconst out = (j.body && j.body.output) || {};\n\nconst invoiceNumber = out.invoice_number || out.invoiceNumber || '';\nconst vendorName = out.vendor_name || out.vendorName || '';\nconst currency = out.currency || '';\nconst invoiceTotal = Number(out.invoice_total ?? out.invoiceTotal ?? NaN);\nconst lines = Array.isArray(out.invoice_lines) ? out.invoice_lines : [];\n\nconst lineSum = lines.reduce((sum, l) => {\n  const amt = Number(l.amount ?? l.total ?? l.line_total ?? 0);\n  return sum + (isNaN(amt) ? 0 : amt);\n}, 0);\n\nconst issues = [];\nif (!invoiceNumber) issues.push('missing invoice number');\nif (!vendorName) issues.push('missing vendor name');\nif (!currency) issues.push('missing currency');\nif (lines.length === 0) issues.push('no line items extracted');\nif (!isNaN(invoiceTotal) && lines.length > 0) {\n  const diff = Math.abs(invoiceTotal - lineSum);\n  if (diff > 0.01 * Math.max(1, invoiceTotal)) {\n    issues.push(`line items sum (${lineSum.toFixed(2)}) does not match invoice total (${invoiceTotal.toFixed(2)})`);\n  }\n} else if (isNaN(invoiceTotal)) {\n  issues.push('missing or unreadable invoice total');\n}\n\nconst needsReview = issues.length > 0;\n\nreturn [{\n  json: {\n    ...$json,\n    invoiceNumber,\n    vendorName,\n    currency,\n    invoiceTotal: isNaN(invoiceTotal) ? null : invoiceTotal,\n    lineSum,\n    issues,\n    needsReview\n  }\n}];\n"
      }
    },
