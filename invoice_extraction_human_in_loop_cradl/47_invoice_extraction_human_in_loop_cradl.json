  "name": "PDF Invoice Extraction with Human-in-the-Loop (Pro)",
  "tags": [],
  "nodes": [
    {
      "id": "c4ca8096-2150-4a4f-af83-3b9e8c030248",
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "position": [
        -160,
        160
      ],
      "typeVersion": 1.3,
      "parameters": {
        "simple": false,
        "filters": {
          "q": "has:attachment subject:invoice",
          "readStatus": "unread"
        },
        "options": {
          "downloadAttachments": true
        },
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        }
      }
    },
    {
      "id": "ca02d52b-9dc1-4658-b3a0-30898cd59757",
      "name": "Filter & Flag Attachments",
      "type": "n8n-nodes-base.code",
      "position": [
        80,
        160
      ],
      "typeVersion": 2,
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Flag each Gmail Trigger item: does it actually have a PDF attachment?\n// This also fixes a real bug in the original workflow: messages matched by the\n// search query but WITHOUT a PDF attachment were never marked as read, so\n// the every-minute poll would keep re-fetching them forever.\nconst results = [];\n\nfor (const item of $input.all()) {\n  const headers = item.json.headers || {};\n  const base = {\n    messageId: item.json.id,\n    threadId: item.json.threadId,\n    subject: headers.subject || item.json.subject || '(no subject)',\n    from: headers.from || item.json.from || ''\n  };\n\n  const binaryKeys = item.binary ? Object.keys(item.binary) : [];\n  const pdfKeys = binaryKeys.filter(k => item.binary[k].fileExtension === 'pdf');\n\n  if (pdfKeys.length === 0) {\n    results.push({ json: { ...base, hasPdf: false, fileName: null } });\n    continue;\n  }\n\n  // One output item per PDF attachment found on the message.\n  for (const key of pdfKeys) {\n    results.push({\n      json: { ...base, hasPdf: true, fileName: item.binary[key].fileName },\n      binary: { data: item.binary[key] }\n    });\n  }\n}\n\nreturn results;\n"
      }
    },
